# API keys - keep real values only in the local .env file.
GEMINI_API_KEY=""
YOUTUBE_API_KEY=""

# Optional application settings.
YOUTUBE_CHANNEL_HANDLE=""
JARVIS_VOICE="Charon"
JARVIS_VOICE_PROVIDER="auto"
JARVIS_WEATHER_LOCATION="Praha"
JARVIS_TIMEZONE="Europe/Prague"

# Optional Google Calendar OAuth files.
GOOGLE_CALENDAR_CREDENTIALS_PATH="config/google_calendar_credentials.json"
GOOGLE_CALENDAR_TOKEN_PATH="runtime/google_calendar_token.json"

# Optional ElevenLabs voice provider.
ELEVENLABS_API_KEY=""
ELEVEN_LABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
ELEVENLABS_MODEL_ID="eleven_multilingual_v2"
ELEVENLABS_OUTPUT_FORMAT="mp3_44100_128"
